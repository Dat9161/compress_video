generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String?
  name        String
  avatarUrl   String?
  provider    Provider @default(LOCAL)
  isVerified  Boolean  @default(false)
  storageUsed BigInt   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs  Job[]
  files File[]

  @@map("users")
}

model Job {
  id           String    @id @default(uuid())
  userId       String
  type         JobType
  status       JobStatus @default(PENDING)
  progress     Int       @default(0)
  inputFile    Json
  outputFile   Json?
  settings     Json
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  files File[]

  @@map("jobs")
}

model File {
  id         String   @id @default(uuid())
  jobId      String?
  userId     String
  type       FileType
  filename   String
  storageKey String
  size       BigInt
  mimeType   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  job  Job?  @relation(fields: [jobId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("files")
}

enum Provider {
  LOCAL
  GOOGLE
}

enum JobType {
  VIDEO_COMPRESS
  VIDEO_EDIT
  IMAGE_EDIT
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum FileType {
  INPUT
  OUTPUT
}
