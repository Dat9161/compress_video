NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/mediapress"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage
UPLOAD_DIR=./uploads
MAX_VIDEO_SIZE_MB=2048
MAX_IMAGE_SIZE_MB=50

# File retention (days)
FILE_RETENTION_DAYS=7

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# FFmpeg binary paths (chỉ cần set nếu ffmpeg không có trong PATH)
# Tải prebuilt tại: https://www.gyan.dev/ffmpeg/builds/ -> ffmpeg-release-essentials.zip
# Giải nén rồi trỏ vào thư mục bin, ví dụ:
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_PATH=C:\ffmpeg\bin\ffprobe.exe
